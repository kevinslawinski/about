{
  "name": "about-me",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "deploy-gh": "ng build && npx angular-cli-ghpages --dir=dist/about-me/browser --cname=slawnet.dev --no-silent",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test-headless": "ng test --no-watch --no-progress --configuration ci"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@angular/platform-server": "^21.2.1",
    "@angular/router": "^21.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@eslint/js": "^9.25.1",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^25.3.5",
    "@vitest/browser-playwright": "^4.0.18",
    "eslint": "^10.0.3",
    "globals": "^16.0.0",
    "jasmine-core": "~5.7.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "express-rate-limit": "8.3.0",
    "hono": "4.12.4",
    "@hono/node-server": "1.19.10",
    "immutable": "5.1.5",
    "tar": "7.5.10"
  }
}
